<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <style>
    body {
      font-family: Arial, sans-serif;
      max-width: 900px;
      margin: 0 auto;
      padding: 20px;
      line-height: 1.5;
    }

    h1, h2 {
      margin-bottom: 10px;
    }

    form {
      margin-bottom: 24px;
    }

    label {
      display: block;
      margin-top: 10px;
      font-weight: bold;
    }

    input {
      width: 100%;
      max-width: 420px;
      padding: 8px;
      margin-top: 4px;
    }

    button {
      margin-top: 12px;
      padding: 8px 12px;
      cursor: pointer;
    }

    .concert-card {
      border: 1px solid #ccc;
      padding: 14px;
      margin-bottom: 14px;
    }

    .error {
      color: red;
      margin-bottom: 12px;
    }

    .inline-form {
      display: inline;
    }

    .actions {
      margin-top: 10px;
    }

    .muted {
      color: #666;
      font-size: 0.95rem;
    }
  </style>
</head>
<body>
  <h1><%= title %></h1>

  <p>Add a concert below. Submitted concerts are saved in MongoDB.</p>

  <% if (errorMessage) { %>
    <div class="error"><%= errorMessage %></div>
  <% } %>

  <form method="POST" action="/concerts/add">
    <label for="title">Concert Title</label>
    <input id="title" name="title" type="text" />

    <label for="city">City</label>
    <input id="city" name="city" type="text" />

    <label for="venue">Venue (optional)</label>
    <input id="venue" name="venue" type="text" />

    <button type="submit">Add Concert</button>
  </form>

  <h2>Concert Listings</h2>

  <% if (!concerts || concerts.length === 0) { %>
    <p class="muted">No concerts have been added yet.</p>
  <% } else { %>
    <% concerts.forEach(function(concert) { %>
      <div class="concert-card">
        <strong><%= concert.title %></strong><br />
        City: <%= concert.city %><br />

        <% if (concert.venue && concert.venue.length > 0) { %>
          Venue: <%= concert.venue %><br />
        <% } %>

        <span class="muted">
          Added: <%= new Date(concert.createdAt).toLocaleString() %>
        </span>

        <div class="actions">
          <a href="/concerts/edit/<%= concert._id %>">Edit</a>

          <form class="inline-form" method="POST" action="/concerts/delete/<%= concert._id %>">
            <button type="submit">Delete</button>
          </form>
        </div>
      </div>
    <% }); %>
  <% } %>
</body>
</html>